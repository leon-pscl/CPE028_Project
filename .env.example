# Supabase credentials — get from Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Geoapify Places API key — get from https://myprojects.geoapify.com
VITE_GEOAPIFY_API_KEY=your-geoapify-key-here

# ML service URL — deployed Cloud Run URL in production, or http://127.0.0.1:8000 locally
# Get URL from GCP Console → Cloud Run → revtech-ml service → URL
VITE_ML_SERVICE_URL=http://127.0.0.1:8000
